# Instala los file:../../packages/* como COPIAS, no symlinks. Esto produce
# un lockfile self-contained que EAS puede instalar con `npm ci` sin depender
# del workspace padre. En dev, Metro lee directamente desde packages/*/src/*
# vía `watchFolders` en metro.config.js — cambios reflejados al vuelo.
install-links=true

# Evita que warnings de peer deps (Clerk pide react ~19.0.3 pero Expo SDK 53
# fija react@19.0.0 exacto) disparen ERESOLVE overriding que desincroniza el
# lockfile. Con esto, npm ignora peer deps al resolver el tree, produciendo
# un lockfile determinístico que `npm ci` puede instalar sin quejarse.
legacy-peer-deps=true
