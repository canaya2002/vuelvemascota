# Mantén los file:../../packages/* como symlinks en lugar de copias, para
# que los cambios en packages/ se reflejen en mobile sin re-instalar.
install-links=false

# Aísla este proyecto del root: npm no busca node_modules hacia arriba.
# Esto evita que se herede la tailwindcss v4 del root (web) cuando mobile
# necesita v3 para NativeWind.
