{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@vuelvecasa/shared": ["../../packages/shared/src/index.ts"],
      "@vuelvecasa/shared/*": ["../../packages/shared/src/*"],
      "@vuelvecasa/design-tokens": ["../../packages/design-tokens/src/index.ts"],
      "@vuelvecasa/design-tokens/*": ["../../packages/design-tokens/src/*"],
      "@vuelvecasa/api-client": ["../../packages/api-client/src/index.ts"],
      "@vuelvecasa/api-client/*": ["../../packages/api-client/src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": ["node_modules", ".expo", "dist", "ios", "android"]
}
