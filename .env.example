# ─────────────────────────────────────────────────────────────────────────────
# VuelveaCasa — Environment variables template
#
# Copia este archivo a `.env.local` (nunca lo commitees) y rellena lo que
# necesites. Todas las integraciones son opcionales: la app arranca sin
# ninguna variable y degrada funcionalidades de forma elegante.
#
# Ver docs/ para el detalle de cada integración (02-stripe, 03-resend,
# 04-supabase, 07-seo, 08-analytics, 09-tiktok, 11-auth).
# ─────────────────────────────────────────────────────────────────────────────

# ── Núcleo ──────────────────────────────────────────────────────────────────
# URL pública del sitio. En dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://vuelvecasa.com

# ── Base de datos (Supabase / Neon / Vercel Postgres) ───────────────────────
# Sin esta variable la app corre en modo stub: forms validan pero no
# persisten, se loggea a consola. Ver docs/04-supabase.md.
DATABASE_URL=

# ── Autenticación (Clerk) ───────────────────────────────────────────────────
# Sin Clerk las rutas /panel y login se deshabilitan. Ver docs/11-auth.md.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# ── Email (Resend) ──────────────────────────────────────────────────────────
# Sin RESEND_API_KEY los emails se loggean pero no se envían.
# EMAIL_FROM formato: "VuelveaCasa <no-reply@tu-dominio.com>"
RESEND_API_KEY=
EMAIL_FROM=
# Inbox del equipo para altas de aliados y formularios de contacto.
# Si están vacíos se usa SITE.contact.email de src/lib/site.ts.
CONTACT_INBOX=
ALIADOS_INBOX=

# ── Donaciones (Stripe) ─────────────────────────────────────────────────────
# Sin Stripe, /donar muestra el CTA informativo pero no cobra.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# IDs de Price (monthly) para suscripciones recurrentes por causa.
STRIPE_PRICE_MONTHLY_FONDO=
STRIPE_PRICE_MONTHLY_EMERGENCIA=
STRIPE_PRICE_MONTHLY_RESCATE=

# ── Push notifications (VAPID) ──────────────────────────────────────────────
# Genera el par con: npx web-push generate-vapid-keys
# Sin estas claves el toggle de push en /panel queda gris.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hola@vuelvecasa.com

# ── Storage (Supabase Storage) ──────────────────────────────────────────────
# Requerido para subir fotos de casos. Sin esto, el formulario acepta
# pero las imágenes no persisten.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# ── Rate limiting (Upstash Redis) ───────────────────────────────────────────
# Opcional. Sin esto, los endpoints protegidos quedan sin rate-limit.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Moderación de contenido ─────────────────────────────────────────────────
# auto | openai | azure | off — default "auto" escoge según qué claves existen.
MODERATION_MODE=auto
OPENAI_API_KEY=
OPENAI_THRESHOLD=0.5
AZURE_CONTENT_SAFETY_ENDPOINT=
AZURE_CONTENT_SAFETY_KEY=
AZURE_SEVERITY_THRESHOLD=4

# ── Mapa (Mapbox) ───────────────────────────────────────────────────────────
# Sin token, los mapas caen a Leaflet/OSM.
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Analytics ───────────────────────────────────────────────────────────────
# GA4 (Google Analytics). Ver docs/08-analytics.md.
NEXT_PUBLIC_GA_ID=

# ── Pixels de ads ───────────────────────────────────────────────────────────
# Meta (Facebook/Instagram) + TikTok. Ver docs/09-tiktok.md.
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# ── Verificación de propiedad del sitio ─────────────────────────────────────
# Meta tags para consolas de Google/Bing/Meta/TikTok. Ver docs/07-seo.md.
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
META_DOMAIN_VERIFICATION=
TIKTOK_DEVELOPERS_VERIFICATION=
